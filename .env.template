# ═══════════════════════════════════════════════════════════
# DASHENG 配置文件模板
# 复制为 .env 后填入你的配置：cp .env.template .env
# 或使用命令：python dasheng.py setup（交互式配置向导）
# ═══════════════════════════════════════════════════════════

# ── LLM 大模型 API ─────────────────────────────────────────
# 支持的提供商（选一个填入 base_url + api_key + model）：

# OpenAI 官方
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o-mini

# Qwen / 通义千问（阿里云）
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MODEL_NAME=qwen-plus

# DeepSeek
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# MODEL_NAME=deepseek-chat

# 智谱 GLM（ChatGLM）
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# MODEL_NAME=glm-4-flash

# 月之暗面 Moonshot（Kimi）
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# MODEL_NAME=moonshot-v1-8k

# 硅基流动 SiliconFlow
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# Agnes AI
# OPENAI_BASE_URL=https://apihub.agnes-ai.com/v1
# MODEL_NAME=agnes-2.0-flash

# 自定义 / 本地模型（如 Ollama, vLLM, llama.cpp server）
# OPENAI_BASE_URL=http://localhost:8000/v1
# MODEL_NAME=your-model-name

OPENAI_BASE_URL=
OPENAI_API_KEY=
MODEL_NAME=

# ── 工具调用 ──────────────────────────────────────────────
# 启用后 Agent 可执行终端命令、读写文件、搜索等
ENABLE_TOOLS=true

# ── Gateway 配置 ──────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=9090

# ── WebServer 配置 ────────────────────────────────────────
DASHENG_API_URL=http://127.0.0.1:7860

# ── QQ Bot 配置（q.qq.com 创建机器人获取）─────────────────
QQ_APP_ID=
QQ_APP_SECRET=
QQ_IS_SANDBOX=true

# ── 微信配置（iLink Bot API 扫码接入）────────────────────
WECHAT_ENABLED=false
# ILINK_BOT_TOKEN=
# ILINK_ACCOUNT_ID=

# ── 日志 ──────────────────────────────────────────────────
# LOG_LEVEL=INFO
# MAX_HISTORY_TURNS=20
